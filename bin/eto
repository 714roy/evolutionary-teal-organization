#!/usr/bin/env bash
# ETO — Evolutionary-Teal Organization
# /ETO — 现在，我们是同志了
# /ETO — Now, we are comrades.
# architecture > agent — Entropy · Trinity · Organic

# ── 配置 ────────────────────────────────────────────
ETO_VERSION="0.3.0"
ETO_DATE="2026-06-20"
ETO_CONFIG="${HOME}/.config/eto/config.yaml"
ETO_TASK_TMP="/tmp/eto-task.txt"
ETO_GLOBAL_WIKI="${HOME}/.eto/wiki"
ETO_LOCAL_WIKI=".eto/wiki"
ETO_PROMPT_FILE=".eto/prompt.md"

# ── 时间感知 ────────────────────────────────────────
get_time_context() {
  local now hour period greeting
  
  now=$(date "+%Y-%m-%d %H:%M:%S %A")
  hour=$(date "+%H")
  weekday=$(date "+%u")  # 1=Mon, 7=Sun
  
  # 时段
  if [ "$hour" -lt 6 ]; then
    period="深夜"; greeting="夜深了"
  elif [ "$hour" -lt 9 ]; then
    period="早晨"; greeting="早上好"
  elif [ "$hour" -lt 12 ]; then
    period="上午"; greeting="上午好"
  elif [ "$hour" -lt 14 ]; then
    period="中午"; greeting="中午好"
  elif [ "$hour" -lt 18 ]; then
    period="下午"; greeting="下午好"
  elif [ "$hour" -lt 21 ]; then
    period="傍晚"; greeting="傍晚好"
  else
    period="夜间"; greeting="晚上好"
  fi
  
  # 周末判断
  local day_type="工作日"
  [ "$weekday" -ge 6 ] && day_type="周末"
  
  echo "🕐 ${now} | ${period} | ${day_type}"
}

# ── Wiki 知识库 ────────────────────────────────────
init_wiki() {
  mkdir -p "$ETO_GLOBAL_WIKI"
  mkdir -p "$ETO_LOCAL_WIKI" 2>/dev/null || true
}

search_wiki() {
  local query="$1"
  local wiki_dir
  local keyword
  local results=""

  # 提取关键词（取任务前 5 个词）
  keyword=$(echo "$query" | grep -oP '[\w\u4e00-\u9fff]+' | head -5 | tr '\n' ' ')

  # 优先搜本地 wiki，再搜全局 wiki
  for wiki_dir in "$ETO_LOCAL_WIKI" "$ETO_GLOBAL_WIKI"; do
    [ -d "$wiki_dir" ] || continue
    local found
    found=$(find "$wiki_dir" -name '*.md' 2>/dev/null | head -20 | while read -r f; do
      if grep -qi "$keyword" "$f" 2>/dev/null; then
        head -30 "$f"
        echo "---"
      fi
    done)
    [ -n "$found" ] && results+="$found" 
  done

  echo "$results"
}

load_project_prompt() {
  local prompt=""
  # 逐级向上找 .eto/prompt.md
  local dir="$PWD"
  while [ "$dir" != "/" ]; do
    if [ -f "$dir/$ETO_PROMPT_FILE" ]; then
      prompt=$(cat "$dir/$ETO_PROMPT_FILE")
      break
    fi
    dir=$(dirname "$dir")
  done
  echo "$prompt"
}

# ── 构建注入上下文 ────────────────────────────────
build_task_context() {
  local task="$1"
  local time_ctx wiki_ctx project_ctx

  time_ctx=$(get_time_context)
  wiki_ctx=$(search_wiki "$task")
  project_ctx=$(load_project_prompt)

  # 组装上下文
  local ctx="[当前时间] ${time_ctx}
"
  if [ -n "$project_ctx" ]; then
    ctx+="
[项目约定]
${project_ctx}
"
  fi
  if [ -n "$wiki_ctx" ]; then
    ctx+="
[知识库参考]
${wiki_ctx}
"
  fi
  ctx+="[任务] ${task}"

  echo "$ctx"
}

# ── 颜色 ────────────────────────────────────────────
RESET='\033[0m'
BOLD='\033[1m'
DIM='\033[2m'
CYAN='\033[36m'
GREEN='\033[32m'
YELLOW='\033[33m'
RED='\033[31m'
MAGENTA='\033[35m'
TEAL='\033[38;5;80m'
ORANGE='\033[38;5;214m'

# ── Banner ──────────────────────────────────────────
print_banner() {
  clear 2>/dev/null || true
  cat << "BANNER_COLOR"
BANNER_COLOR

  # Colored banner with ASCII art
  echo -e "${TEAL}${BOLD}"
  echo "             ╔══════════════════════════════════════╗"
  echo "             ║                                      ║"
  echo "             ║   /ETO                               ║"
  echo "             ║   现在，我们是同志了                    ║"
  echo "             ║   Now, we are comrades.               ║"
  echo "             ║                                      ║"
  echo "             ║   ${DIM}architecture > agent${RESET}${TEAL}${BOLD}            ║"
  echo "             ║   ${DIM}无序 · 三生 · 有机${RESET}${TEAL}${BOLD}               ║"
  echo "             ║   ${DIM}Entropy · Trinity · Organic${RESET}${TEAL}${BOLD}       ║"
  echo "             ║                                      ║"
  echo "             ╚══════════════════════════════════════╝"
  echo -e "${RESET}"
}

# ── Agent 检测 ──────────────────────────────────────
detect_agents() {
  local agents=""

  # Claude Code
  if command -v claude &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} Claude Code${RESET}\n"
  else
    agents+="  ${DIM}⬜ Claude Code${RESET}\n"
  fi

  # Reasonix
  if command -v reasonix &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} Reasonix${RESET}\n"
  else
    agents+="  ${DIM}⬜ Reasonix${RESET}\n"
  fi

  # Pi / OMP
  if command -v pi &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} Pi (pi-mono)${RESET}\n"
  else
    agents+="  ${DIM}⬜ Pi (pi-mono)${RESET}\n"
  fi

  # Codex CLI
  if command -v codex &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} Codex CLI${RESET}\n"
  else
    agents+="  ${DIM}⬜ Codex CLI${RESET}\n"
  fi

  # Goose
  if command -v goose &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} Goose${RESET}\n"
  else
    agents+="  ${DIM}⬜ Goose${RESET}\n"
  fi

  # OpenHands
  if command -v openhands &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} OpenHands${RESET}\n"
  else
    agents+="  ${DIM}⬜ OpenHands${RESET}\n"
  fi

  # Cline
  if command -v cline &>/dev/null; then
    agents+="  ${GREEN}✅${RESET} Cline${RESET}\n"
  else
    agents+="  ${DIM}⬜ Cline${RESET}\n"
  fi

  echo -e "$agents"
}

# ── 任务分流 ──────────────────────────────────────
route_task() {
  local task="$1"
  local mode="${2:-auto}"
  local task_ctx

  # 构建完整上下文（时间 + wiki + 项目 prompt + 任务）
  task_ctx=$(build_task_context "$task")

  echo -e "\n${TEAL}🔄 编排中...${RESET}"
  sleep 0.2

  case "$mode" in
    code|build)
      echo -e "  ${CYAN}→${RESET} MODE: build   ${DIM}方案→编码→审查${RESET}"
      echo -e "  ${DIM}  ${time_ctx}${RESET}"
      if command -v claude &>/dev/null; then
        echo -e "  ${CYAN}→${RESET} 调用: ${GREEN}Claude Code${RESET}"
        echo -e "${DIM}"
        claude -p "$task_ctx"
        echo -e "${RESET}"
      else
        echo -e "  ${YELLOW}⚠ Claude Code 不可用${RESET}"
        echo -e "\n${TEAL}━━━ 任务上下文 ━━━${RESET}"
        echo "  $task_ctx"
        echo -e "${TEAL}━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
        read -r -p "回答 > " response
        echo -e "\n${response}"
      fi
      ;;
    research|study)
      echo -e "  ${CYAN}→${RESET} MODE: research ${DIM}调研→分析→汇总${RESET}"
      echo -e "  ${DIM}  ${time_ctx}${RESET}"
      if command -v reasonix &>/dev/null; then
        echo -e "  ${CYAN}→${RESET} 调用: ${GREEN}Reasonix${RESET}"
        echo -e "${DIM}"
        reasonix run "$task_ctx"
        echo -e "${RESET}"
      else
        echo -e "  ${YELLOW}⚠ Reasonix 不可用${RESET}"
        echo -e "\n${TEAL}━━━ 任务（含时间上下文）━━━${RESET}"
        echo "  $task_ctx"
        echo -e "${TEAL}━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
        read -r -p "回答 > " response
        echo -e "\n${response}"
      fi
      ;;
    direct|quick)
      echo -e "  ${CYAN}→${RESET} MODE: direct ${DIM}直达${RESET}"
      echo -e "  ${DIM}  ${time_ctx}${RESET}"
      if command -v reasonix &>/dev/null; then
        echo -e "  ${CYAN}→${RESET} 调用: ${GREEN}Reasonix (direct)${RESET}"
        echo -e "${DIM}"
        reasonix run "$task_ctx"
        echo -e "${RESET}"
      elif command -v claude &>/dev/null; then
        echo -e "  ${CYAN}→${RESET} 调用: ${GREEN}Claude Code (direct)${RESET}"
        echo -e "${DIM}"
        claude -p "$task_ctx"
        echo -e "${RESET}"
      else
        echo -e "\n${TEAL}━━━ 任务（含时间上下文）━━━${RESET}"
        echo "  $task_ctx"
        echo -e "${TEAL}━━━━━━━━━━━━━━━━━━━━━━━${RESET}\n"
        read -r -p "回答 > " response
        echo -e "\n${response}"
      fi
      ;;
    *)
      # auto — 简单判断
      if echo "$task" | grep -qiE "代码|重构|写个|实现|bug|修|函数|API|路由"; then
        route_task "$task" "build"
      elif echo "$task" | grep -qiE "研究|分析|调研|论文|搜索|对比|趋势"; then
        route_task "$task" "research"
      else
        route_task "$task" "direct"
      fi
      ;;
  esac
}

# ── 主流程 ──────────────────────────────────────────
main() {
  local task=""
  local mode="auto"

  # 解析参数
  while [[ $# -gt 0 ]]; do
    case "$1" in
      --mode|-m)
        mode="$2"; shift 2 ;;
      --wiki)
        init_wiki
        echo "📚 ETO Wiki"
        echo "  全局: $ETO_GLOBAL_WIKI"
        echo "  本地: $(pwd)/$ETO_LOCAL_WIKI"
        ls "$ETO_GLOBAL_WIKI"/*.md 2>/dev/null | while read -r f; do
          title=$(head -5 "$f" | grep "^title:" | sed 's/title: *//')
          echo "  📄 $(basename "$f" .md): ${title:-$(basename "$f" .md)}"
        done
        ls "$ETO_LOCAL_WIKI"/*.md 2>/dev/null | while read -r f; do
          title=$(head -5 "$f" | grep "^title:" | sed 's/title: *//')
          echo "  📄 📍 $(basename "$f" .md): ${title:-$(basename "$f" .md)}"
        done
        exit 0 ;;
      --help|-h)
        echo "ETO — Evolutionary-Teal Organization"
        echo "用法: ETO [任务] [选项]"
        echo "       ETO                      → 交互模式"
        echo "       ETO 帮我重构这个函数       → 直接任务"
        echo "       ETO --mode research 调研   → 指定模式"
        echo "       ETO --wiki                → 查看知识库"
        echo "       ETO --help                → 本帮助"
        exit 0 ;;
      *)
        task="$*"; break ;;
    esac
  done

  # 初始化 wiki 目录
  init_wiki

  print_banner

  # 时间感知
  local time_info
  time_info=$(get_time_context)
  echo -e "  ${TEAL}${BOLD}⏰ ${time_info}${RESET}"
  echo

  # 系统状态
  echo -e "  ${TEAL}${BOLD}✦ 本机 Agent 检测${RESET}"
  printf '  %.0s─' {1..35}; echo
  detect_agents
  printf '  %.0s─' {1..35}; echo
  echo -e "  ${DIM}ETO v${ETO_VERSION} | ${ETO_DATE}${RESET}"
  echo

  # ── 交互 / 任务模式 ──────────────────────────────
  if [[ -z "$task" ]]; then
    # 交互模式
    echo -e "  ${TEAL}${BOLD}⚡ 陛下有何吩咐？${RESET}"
    echo -e "  ${DIM}  可指定模式: --mode build / research / direct${RESET}"
    echo -e "  ${DIM}  退出: Ctrl+C 或输入 exit${RESET}\n"
    printf "  "
    read -r task
    if [[ "$task" == "exit" || "$task" == "quit" ]]; then
      echo -e "\n  ${TEAL}${BOLD}同志，后会有期。${RESET}\n"
      exit 0
    fi
  fi

  if [[ -n "$task" ]]; then
    echo "$task" > "$ETO_TASK_TMP"
    route_task "$task" "$mode"
    # 有任务参数时跑完就退，不进交互循环
    exit 0
  fi

  # 交互模式循环
  while true; do
    echo
    printf "  ⚡ "
    read -r task
    if [[ "$task" == "exit" || "$task" == "quit" ]]; then
      echo -e "\n  ${TEAL}${BOLD}同志，后会有期。${RESET}\n"
      break
    fi
    if [[ -n "$task" ]]; then
      echo "$task" > "$ETO_TASK_TMP"
      route_task "$task" "$mode"
    fi
  done
}

main "$@"
